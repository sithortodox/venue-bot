# ============================================
# Конфигурация Venue Bot
# Скопируй в .env и заполни значения
# ============================================

# Telegram
BOT_TOKEN=your_bot_token_here          # Токен от @BotFather
ADMIN_TELEGRAM_ID=your_telegram_id     # Твой Telegram ID (для уведомлений)
BOT_WEBHOOK_URL=https://your-domain.com/bot/webhook
MINI_APP_URL=https://your-domain.com/app

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://venue:venue_secret@db:5432/venue_db

# Redis (кэш, сессии)
REDIS_URL=redis://redis:6379/0

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production      # Секрет для подписей JWT/токенов

# Mini App (React)
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=3000
